# ── Git LFS: large test datasets ──────────────────────────────────────────────
# Binary dataset formats go through LFS wherever they sit on the fixture/sample
# paths; TEXT fixtures (json/yaml/csv small enough to review) stay plain git so
# diffs remain readable. Scoped by path+format on purpose — a blanket `*.zip`
# would LFS-ify unrelated artifacts, and LFS-ing small JSON would make every
# fixture change an opaque pointer swap.
#
# Enforced by .ci/steps/lfs-guard.sh (CI half; cannot be skipped) — any tracked
# blob over the size limit that is not an LFS pointer fails the build.
# One-time per clone: `git lfs install --local` (or `make lfs-install`).

# Test datasets (recorded scrape fixtures, sampled dumps, parquet cases)
src/tests/data/**/*.parquet   filter=lfs diff=lfs merge=lfs -text
src/tests/data/**/*.zip       filter=lfs diff=lfs merge=lfs -text
src/tests/data/**/*.gz        filter=lfs diff=lfs merge=lfs -text
src/tests/data/**/*.duckdb    filter=lfs diff=lfs merge=lfs -text
src/tests/data/**/*.sqlite    filter=lfs diff=lfs merge=lfs -text

# Ingestion samples (bundled demo inputs — rawg_games.json stays plain text)
ingestion/samples/**/*.parquet filter=lfs diff=lfs merge=lfs -text
ingestion/samples/**/*.zip     filter=lfs diff=lfs merge=lfs -text
ingestion/samples/**/*.gz      filter=lfs diff=lfs merge=lfs -text

# Published example outputs (ML-ready parquet snapshots for docs/notebooks)
examples/**/*.parquet          filter=lfs diff=lfs merge=lfs -text
