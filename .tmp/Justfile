# .tmp/Justfile — local recipes for temporary/working scripts.
# Run with:  just -f .tmp/Justfile <recipe>
# Everything in .tmp/ is gitignored except this file and README.md.
# Graduate durable recipes → root Justfile / integrations/ / skills / src/ (see README.md).

# List available temp recipes (default).
default:
    @just -f .tmp/Justfile --list

# List working scripts currently in .tmp/.
ls:
    @ls -1 .tmp/*.sh .tmp/*.py 2>/dev/null || echo "(no temp scripts yet)"

# Run a one-shot from .tmp/.once/ (e.g. `just -f .tmp/Justfile once bootstrap.sh`).
once script:
    @test -f ".tmp/.once/{{script}}" || { echo "not found: .tmp/.once/{{script}}"; exit 1; }
    bash ".tmp/.once/{{script}}"

# Reminder to graduate a durable script out of .tmp/ (see README.md graduation rule).
graduate script:
    @echo "Graduate .tmp/{{script}} → integrations/ | skills | src/ (then delete it from .tmp/)."

# --- Agentic-observability spike (#33; README.md § One-shot bundles; contents gitignored) ---

# Phase-0 OTel spike: one throwaway telemetry-enabled haiku session, then all checks.
agentic-otel-spike:
    @test -f "{{justfile_directory()}}/agentic-otel-spike.sh" \
      || { echo "spike absent — see MANIFEST.agentic-obs.md"; exit 1; }
    bash "{{justfile_directory()}}/agentic-otel-spike.sh"

# Read-only re-check: did agent telemetry land in VM / Alloy / Loki? Idempotent.
agentic-otel-check:
    @test -f "{{justfile_directory()}}/agentic-otel-check.sh" \
      || { echo "check absent — see MANIFEST.agentic-obs.md"; exit 1; }
    bash "{{justfile_directory()}}/agentic-otel-check.sh"

# --- One-shot bundles (documented in README.md § One-shot bundles; contents gitignored) ---

# Run the 2026-07-19 sources batch (difficult-scraping + Airbyte registry entries).
# Idempotent; see .tmp/.once/MANIFEST.sources-batch-scrape-airbyte.md for context/evidence.
once-sources-batch *args:
    python3 "{{justfile_directory()}}/.once/sources-batch-scrape-airbyte.py" {{args}}

# Verify the VPS-provisioning + skills bundle is intact (read-only; no box, no token, no writes).
# Path via justfile_directory(): `just` runs recipes from the Justfile's own dir, so a bare
# `.tmp/.once/…` would double-prefix. The script cd's to the repo root itself.
verify-vps-provisioning:
    @test -f "{{justfile_directory()}}/.once/setup-vps-provisioning.sh" \
      || { echo "bundle absent — see README.md § One-shot bundles"; exit 1; }
    bash "{{justfile_directory()}}/.once/setup-vps-provisioning.sh"
