{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.ai/skills/_scripts/session/session-lock-hook.sh\" on-start",
            "timeout": 10,
            "statusMessage": "session-lock"
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.ai/skills/_scripts/session/session-state-hook.sh\" on-resume",
            "timeout": 10,
            "statusMessage": "session-state"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.ai/skills/_scripts/session/session-lock-hook.sh\" on-end",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
