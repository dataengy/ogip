{
  "uid": "ogip-observability",
  "title": "OGIP — Pipeline & Stack",
  "description": "Phase 7 baseline: stack health (VictoriaMetrics) + pipeline logs (Loki via Alloy). Pipeline metrics light up once the flow pushes OTLP to Alloy:4318.",
  "tags": ["ogip", "observability"],
  "timezone": "browser",
  "editable": false,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Stack health",
      "description": "Scrape targets reported UP by VictoriaMetrics.",
      "datasource": { "type": "prometheus", "uid": "ogip-victoriametrics" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "up",
          "legendFormat": "{{job}}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Pipeline log volume by level",
      "description": "Requires log_json=true in config/config.yml — plain-text lines carry no level label.",
      "datasource": { "type": "loki", "uid": "ogip-loki" },
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (level) (count_over_time({job=\"ogip\"} [$__auto]))",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ERROR" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Pipeline metrics (OTLP → VictoriaMetrics)",
      "description": "Empty until the flow is instrumented — lane `core-pipeline` owns src/ogip + pipelines/. Contract: OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318, metric prefix ogip_.",
      "datasource": { "type": "prometheus", "uid": "ogip-victoriametrics" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "refId": "A",
          "expr": "{__name__=~\"ogip_.*\"}",
          "legendFormat": "{{__name__}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Loki ingest rate (lines/s)",
      "description": "Alloy → Loki throughput, from Loki's own metrics.",
      "datasource": { "type": "prometheus", "uid": "ogip-victoriametrics" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(loki_distributor_lines_received_total[$__rate_interval]))",
          "legendFormat": "lines/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20 } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Recent errors & warnings",
      "description": "A matches JSON logs on the parsed `level` label. B is the plain-text fallback: Alloy renders JSON lines down to their message, so a text filter alone would miss them — an ERROR whose message never says \"error\" is still an ERROR.",
      "datasource": { "type": "loki", "uid": "ogip-loki" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 13 },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"ogip\"} | level=~\"ERROR|CRITICAL|WARNING\""
        },
        {
          "refId": "B",
          "expr": "{job=\"ogip\"} | level=\"\" |~ \"(?i)error|critical|warning\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
