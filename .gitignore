# --- Runtime (everything transient lives under .run/) ---
.run/
# canonical venv is .run/venv (UV_PROJECT_ENVIRONMENT); ignore the stray default
.venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/

# --- Secrets & local config (root-anchored; tracked blank templates live in config/) ---
/.env
/.env.*
.dlt/secrets.toml
# git-secret (opt-in): encrypted *.secret blobs are committed; plaintext never
config/secrets/*.secret

# --- Temp: everything in .tmp/ is ignored EXCEPT the tracked README + Justfile ---
/.tmp/*
!/.tmp/README.md
!/.tmp/Justfile

# --- Warehouse artifacts (safety net; canonical home is .run/data/) ---
*.duckdb
*.duckdb.wal

# --- Experimental engines / BI (off the production path) ---
experimental/**/target/
experimental/**/.cache/
experimental/**/logs/
experimental/**/.bruin/
experimental/bi/evidence/node_modules/
experimental/bi/evidence/.evidence/

# --- Orchestration / tools ---
.prefect/
# stray CWD logs (canonical home is .run/logs/) + dlt local state
logs/
.dlt/

# --- SQLMesh: generated models + local cache/logs (spec/ is the SSoT) ---
transform/sqlmesh/models/
transform/sqlmesh/.cache/
transform/sqlmesh/logs/

# --- OS / editor ---
.DS_Store
.idea/
.vscode/

# --- Integrations: local configs (templates are tracked) ---
integrations/*/config.yml

# --- .ai machine-specific symlinks (in-repo specs/scripts symlinks stay tracked) ---
/.ai/memory
/.ai/skills
/.ai/.locks/
